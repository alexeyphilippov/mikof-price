DATABASE_URL=postgresql+asyncpg://mikof:changeme@db:5432/mikofai
SECRET_KEY=change-me-to-a-random-32-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
SMTP_HOST=smtp.example.com
SMTP_PORT=1127
SMTP_LOGIN=your-smtp-login
SMTP_PASSWORD=your-smtp-password
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
SEED_PASSWORD=change-me
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
POSTGRES_USER=mikof
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mikofai
# noreply@<домен>; адрес отправителя писем (должен быть разрешён SMTP-провайдером)
MAIL_FROM=noreply@example.com
# Продакшн: cookie только по HTTPS и разрешённые источники CORS
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:5173
# Лимит попыток входа на IP (прод-рекомендация 5/minute)
LOGIN_RATE_LIMIT=5/minute
